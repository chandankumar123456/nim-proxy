# =============================================================================
# NIM-PROXY: Anthropic-Compatible LLM Router
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before starting the server.

# -----------------------------------------------------------------------------
# Router Server Settings
# -----------------------------------------------------------------------------
ROUTER_HOST=0.0.0.0
ROUTER_PORT=8080

# Maximum simultaneous in-flight requests (rejects beyond this with 529)
MAX_CONCURRENT_REQUESTS=50

# Maximum requests allowed to queue when at capacity (rejects beyond this)
MAX_QUEUE_SIZE=100

# Maximum total retries across providers per request (max 2)
MAX_RETRIES=2

# -----------------------------------------------------------------------------
# Routing Thresholds
# -----------------------------------------------------------------------------
# Total character count of all messages that triggers NVIDIA routing
LONG_PROMPT_THRESHOLD=2000

# Number of messages in the conversation that triggers NVIDIA routing
MANY_MESSAGES_THRESHOLD=10

# -----------------------------------------------------------------------------
# Ollama Provider (Primary)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Timeouts in seconds
OLLAMA_TIMEOUT_CONNECT=10
OLLAMA_TIMEOUT_RESPONSE=30
OLLAMA_TIMEOUT_STREAM_IDLE=60
OLLAMA_TIMEOUT_TOTAL=300

# Maximum context tokens Ollama can handle (for truncation)
OLLAMA_MAX_TOKENS=8192

# -----------------------------------------------------------------------------
# NVIDIA NIM Provider (Fallback)
# -----------------------------------------------------------------------------
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Timeouts in seconds
NVIDIA_TIMEOUT_CONNECT=10
NVIDIA_TIMEOUT_RESPONSE=30
NVIDIA_TIMEOUT_STREAM_IDLE=60
NVIDIA_TIMEOUT_TOTAL=300

# Maximum context tokens NVIDIA can handle (for truncation)
NVIDIA_MAX_TOKENS=32768

# NVIDIA rate-limit cooldown seconds before retrying (after 429)
NVIDIA_RATE_LIMIT_COOLDOWN=60

# -----------------------------------------------------------------------------
# Claude Code Integration
# -----------------------------------------------------------------------------
# Point Claude Code at this router:
#   ANTHROPIC_BASE_URL=http://localhost:8080
#   ANTHROPIC_API_KEY=dummy-key-not-checked
